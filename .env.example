# ── RPC & Chain ────────────────────────────────────────────────────────────────
RPC_URL=https://ethereum-sepolia.publicnode.com
CHAIN_ID=11155111

# ── Deployed contract addresses (fill after forge script Deploy) ───────────────
CONTRACT_DEPLOY_BLOCK=0
PERP_ADDRESS=0x...
USDC_ADDRESS=0x...
PRICE_FEED_ADDRESS=0x...
MARKET_SYMBOL=BTC-USD
NEXT_PUBLIC_MARKET_SYMBOL=BTC-USD

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── Deployment keys (NEVER commit real values) ─────────────────────────────────
PRIVATE_KEY=0x...
ETHERSCAN_API_KEY=your_etherscan_api_key

# ── Indexer tuning (optional) ──────────────────────────────────────────────────
INDEXER_BATCH_SIZE=2000
# Poll interval (ms). Higher = fewer RPC calls; demo on Infura free tier: try 8000–12000.
INDEXER_POLL_MS=6000
# Reorg safety window (blocks). Smaller = less getLogs work per poll; Sepolia demo often 24–32 is enough.
INDEXER_REORG_BUFFER=64
# Set to false to use only RPC_URL (saves quota when you do not want fallback public RPCs).
INDEXER_RPC_FALLBACK=true
